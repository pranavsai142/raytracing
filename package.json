{
  "name": "oceanscape-web",
  "version": "1.0.0",
  "description": "Three.js path tracer — accurate light physics at the water surface",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx gh-pages -d dist",
    "smoke": "BASE_URL=${BASE_URL:-http://127.0.0.1:5173/raytracing/} node scripts/visual-smoke.mjs",
    "smoke:headed": "HEADED=1 BASE_URL=${BASE_URL:-http://127.0.0.1:5173/raytracing/} node scripts/visual-smoke.mjs"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "gh-pages": "^6.2.0",
    "playwright": "^1.51.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
